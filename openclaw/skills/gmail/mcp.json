{
    "mcpServers": {
       "gmail": {
          "command": "npx",
          "args": [
              "@shizaolabs/gmail-mcp"
          ],
          "env": {
              "CLIENT_ID": "<Client ID sourced from Google Cloud>.apps.googleusercontent.com",
              "CLIENT_SECRET": "<Client Secret sourced from Google Cloud>"
          }
      }
   }
}