{
  "secrets": {
    "providers": {
      "aws_email": {
        "source": "exec",
        "allowSymlinkCommand": true,
        "command": "/home/openclaw/.openclaw/get_aws_secret.sh",
        "args": ["dev/OpenClaw/Email"],
        "jsonOnly": false
      }
    }
  },
  "mcpServers": {
    "zerolib-email": {
      "command": "uvx",
      "args": ["mcp-email-server@latest", "stdio"],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "Joshua",
        "MCP_EMAIL_SERVER_FULL_NAME": "Joshua Haupt OpenClaw",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "joshua@jnh.dev",
        "MCP_EMAIL_SERVER_USER_NAME": "joshua@jnh.dev",
        "MCP_EMAIL_SERVER_PASSWORD": { 
            "source": "exec", 
            "provider": "aws_email", 
            "id": "value" 
        },
        "MCP_EMAIL_SERVER_IMAP_HOST": "mail.privateemail.com",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_SMTP_HOST": "mail.privateemail.com",
        "MCP_EMAIL_SERVER_SMTP_PORT": "465"
      }
    }
  }
}